# ===========================================
# Database Configuration
# ===========================================
# Copy this file to .env and fill in your values:
#   cp example.env .env
#
# Note: SQLite databases don't need this file,
# just use: python db_extractor.py --sqlite path/to/db.sqlite
# ===========================================

# Database Type
# Supported: postgresql, mysql, mariadb
DB_TYPE=postgresql

# Connection Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database_name

# ===========================================
# Common Port Numbers:
#   PostgreSQL: 5432
#   MySQL/MariaDB: 3306
#   SQL Server: 1433
# ===========================================

# Alternative variable names (also supported for MySQL compatibility)
# DB_IP=localhost
# DB_USERNAME=your_username
# DB_PASS=your_password
# DB_DATABASE=your_database_name
